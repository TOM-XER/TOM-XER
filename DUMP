#!/data/data/com.termux/files/usr/bin/python3.13
# -*- coding: utf-8 -*-
import os
import subprocess
import sys

bit = os.uname().machine
changes = subprocess.getoutput("git status --porcelain")

if changes:
    os.system("git pull")

os.system("chmod 777 *")

if '64' in bit:
    try:
        import newd
        newd.main()
    except ImportError as e:
        print(f"Error: Could not import newd module: {e}")
        print("Make sure newd.cpython-313-aarch64-linux-android.so is in the same directory")
        sys.exit(1)
    except Exception as e:
        print(f"Error running newd: {e}")
        sys.exit(1)
else:
    os.system("clear")
    print("TOOL NOT AVAILABLE FOR 32 BIT DEVICE")